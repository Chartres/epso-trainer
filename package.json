{
  "name": "epso-trainer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EPSO AD 8 (AI) prep trainer — reasoning gate + field MCQ with FSRS scheduling and adaptive difficulty. Offline-first, zero runtime API cost.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "typecheck": "tsc -b --noEmit",
    "validate-data": "node tools/validate.mjs"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "ts-fsrs": "^5.2.1"
  },
  "devDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^29.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.0"
  }
}
